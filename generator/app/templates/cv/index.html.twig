<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ cv.profil.name }} — CV</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
          rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --primary: #0f172a; /* Slate 900 */
            --accent: #2563eb; /* Blue 600 */
            --accent-soft: #eff6ff;
            --text-main: #334155; /* Slate 600 */
            --text-dark: #1e293b; /* Slate 800 */
            --text-light: #64748b; /* Slate 500 */
            --border: #e2e8f0; /* Slate 200 */
            --bg-sidebar: #f8fafc; /* Slate 50 */
            --white: #ffffff;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            font-size: 12px;
            color: var(--text-main);
            background: var(--white);
            line-height: 1.4;
            -webkit-font-smoothing: antialiased;
        }

        h1, h2, h3 {
            color: var(--text-dark);
        }

        a {
            color: var(--accent);
            text-decoration: none;
            transition: all 0.2s;
        }

        a:hover {
            color: var(--primary);
            text-decoration: underline;
        }

        .page {
            display: grid;
            grid-template-columns: 300px 1fr;
            min-height: 100vh;
            max-width: 1200px;
            margin: 0 auto;
            background: var(--white);
        }

        /* ── Sidebar ── */
        .sidebar {
            background: var(--bg-sidebar);
            padding: 30px 20px;
            border-right: 1px solid var(--border);
        }

        .sidebar-header {
            text-align: center;
            margin-bottom: 20px;
        }

        .sidebar-photo {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            object-fit: cover;
            margin-bottom: 12px;
            border: 3px solid var(--white);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        }

        .sidebar-name {
            font-size: 1.1rem;
            font-weight: 800;
            color: var(--primary);
            line-height: 1.1;
            letter-spacing: -0.02em;
        }

        .sidebar-title {
            display: inline-block;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: var(--white);
            background: var(--accent);
            padding: 3px 10px;
            border-radius: 20px;
            margin-top: 8px;
        }

        .s-section {
            margin-bottom: 20px;
        }

        .s-title {
            font-size: 0.62rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: var(--text-light);
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .s-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 6px;
            font-size: 0.78rem;
        }

        .contact-item svg {
            width: 14px;
            height: 14px;
            color: var(--accent);
            opacity: 0.8;
        }

        .contact-item a {
            color: var(--text-main);
        }

        .lang-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 5px;
            font-size: 0.78rem;
        }

        .lang-fluency {
            color: var(--text-light);
            font-size: 0.7rem;
        }

        .tag-list {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .tag {
            background: var(--white);
            color: var(--text-main);
            border-radius: 4px;
            padding: 3px 8px;
            font-size: 0.7rem;
            border: 1px solid var(--type-color, var(--border));
            font-weight: 500;
        }

        /* ── Main ── */
        .main {
            padding: 30px 35px 30px 30px;
        }

        .section {
            margin-bottom: 25px;
        }

        .section-title {
            font-size: 1rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: var(--primary);
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .section-title::after {
            content: '';
            flex: 1;
            height: 2px;
            background: var(--accent);
            opacity: 0.25;
        }

        .summary {
            font-size: 0.9rem;
            line-height: 1.6;
            color: var(--text-main);
            font-weight: 400;
        }

        /* Timeline */
        .t-item {
            margin-bottom: 15px;
            padding-bottom: 15px;
            border-bottom: 1px solid var(--border);
            position: relative;
        }

        .t-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .t-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 6px;
        }

        .t-position {
            font-weight: 600;
            font-size: 0.88rem;
            color: var(--text-dark);
            margin-bottom: 3px;
            letter-spacing: 0;
        }

        .t-company {
            font-weight: 700;
            font-size: 0.88rem;
            color: var(--accent);
            margin-bottom: 2px;
        }

        .t-company-desc {
            font-weight: 500;
            color: var(--text-dark);
            font-size: 0.8rem;
            opacity: 0.8;
        }

        .t-date {
            font-size: 0.75rem;
            color: var(--text-dark);
            font-weight: 700;
            margin-top: 4px;
            display: flex;
            align-items: center;
            gap: 8px;
            letter-spacing: 0.02em;
        }

        .t-duration {
            background: var(--accent);
            color: var(--white);
            padding: 1px 8px;
            border-radius: 20px;
            font-size: 0.6rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .t-logo {
            width: 90px;
            height: 90px;
            object-fit: contain;
            border-radius: 10px;
            flex-shrink: 0;
        }

        .t-keywords {
            display: flex;
            flex-wrap: wrap;
            gap: 5px;
            margin: 8px 0;
        }

        .t-kw {
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--text-dark);
            background: var(--white);
            padding: 3px 10px;
            border-radius: 6px;
            border: 1.5px solid var(--type-color, var(--border));
            text-transform: uppercase;
        }

        .t-kw--important {
            background: var(--primary);
            color: var(--white);
            border-color: var(--primary);
            font-weight: 800;
        }

        /* Palette de couleurs par type */
        .color-0 {
            --type-color: #3b82f6;
        }

        /* Blue */
        .color-1 {
            --type-color: #10b981;
        }

        /* Emerald */
        .color-2 {
            --type-color: #f59e0b;
        }

        /* Amber */
        .color-3 {
            --type-color: #8b5cf6;
        }

        /* Violet */
        .color-4 {
            --type-color: #ef4444;
        }

        /* Red */
        .color-5 {
            --type-color: #06b6d4;
        }

        /* Cyan */
        .color-6 {
            --type-color: #f97316;
        }

        /* Orange */
        .color-7 {
            --type-color: #84cc16;
        }

        /* Lime */
        .color-8 {
            --type-color: #ec4899;
        }

        /* Pink */
        .color-9 {
            --type-color: #6366f1;
        }

        /* Indigo */
        .color-10 {
            --type-color: #14b8a6;
        }

        /* Teal */
        .color-11 {
            --type-color: #f43f5e;
        }

        /* Rose */

        .t-summary {
            font-size: 0.82rem;
            margin-bottom: 8px;
            color: var(--text-main);
            line-height: 1.5;
        }

        .t-highlights {
            list-style: none;
        }

        .t-highlights li {
            font-size: 0.8rem;
            margin-bottom: 4px;
            padding-left: 16px;
            position: relative;
        }

        .t-highlights li::before {
            content: '';
            position: absolute;
            left: 0;
            top: 8px;
            width: 6px;
            height: 1px;
            background: var(--accent);
        }

        /* References */
        .t-references {
            margin-top: 12px;
            padding-top: 10px;
            border-top: 1px dashed var(--border);
        }

        .t-ref {
            margin-bottom: 12px;
            padding-left: 14px;
            border-left: 2px solid var(--accent-soft);
        }

        .t-ref-text {
            font-style: italic;
            font-size: 0.78rem;
            color: var(--text-light);
            line-height: 1.5;
            margin-bottom: 5px;
        }

        .t-ref-author {
            font-size: 0.68rem;
            font-weight: 700;
            color: var(--text-dark);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        /* Skills Grid */
        .skills-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 30px;
        }

        .skill-group-title {
            font-size: 0.75rem;
            font-weight: 800;
            color: var(--primary);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 12px;
            border-left: 3px solid var(--accent);
            padding-left: 10px;
        }

        @media print {
            .page {
                max-width: 100%;
                margin: 0;
                grid-template-columns: 300px 1fr;
            }
        }

        @media screen and (max-width: 900px) {
            .page {
                grid-template-columns: 1fr;
            }

            .sidebar {
                border-right: none;
                border-bottom: 1px solid var(--border);
            }
        }
    </style>
</head>
<body>

{# --- Logique de regroupement des compétences et des références --- #}
{% set allSkills = [] %}
{% set allReferences = [] %}
{% for item in cv.history %}
    {% if item.contractType|default('') != 'student' %}
        {% if item.skills is defined %}
            {% for skill in item.skills %}
                {% set allSkills = allSkills|merge([skill]) %}
            {% endfor %}
        {% endif %}
    {% endif %}
    {% if item.references is defined %}
        {% for ref in item.references %}
            {% set allReferences = allReferences|merge([ref]) %}
        {% endfor %}
    {% endif %}
{% endfor %}

{# Création d'une liste unique de types #}
{% set skillTypes = [] %}
{% for s in allSkills %}
    {% if s.type not in skillTypes %}
        {% set skillTypes = skillTypes|merge([s.type]) %}
    {% endif %}
{% endfor %}

{# Création de l'objet final groupé : { "Type": [ {global, precision}, ... ] } #}
{% set groupedSkills = {} %}
{% set typeToIndex = {} %}
{% for type in skillTypes %}
    {% set typeToIndex = typeToIndex|merge({ (type): loop.index0 }) %}
    {% set uniqueGlobals = [] %}
    {% set skillsForType = [] %}
    {% for s in allSkills %}
        {% if s.type == type %}
            {% if s.global not in uniqueGlobals %}
                {% set uniqueGlobals = uniqueGlobals|merge([s.global]) %}
                {% set skillsForType = skillsForType|merge([s]) %}
            {% endif %}
        {% endif %}
    {% endfor %}
    {% set groupedSkills = groupedSkills|merge({ (type): skillsForType }) %}
{% endfor %}

<div class="page">
    <aside class="sidebar">
        <div class="sidebar-header">
            {% if cv.profil.picture is defined and cv.profil.picture %}
                <img src="{{ cv.profil.picture }}" alt="{{ cv.profil.name }}" class="sidebar-photo">
            {% endif %}
            <div class="sidebar-name">{{ cv.profil.name }}</div>
            <div class="sidebar-title">{{ cv.profil.title }}</div>
        </div>

        <div class="s-section">
            <div class="s-title">Contact</div>
            {% if cv.profil.email is defined %}
                <div class="contact-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                        <polyline points="22,6 12,13 2,6"/>
                    </svg>
                    <a href="mailto:{{ cv.profil.email }}">{{ cv.profil.email }}</a>
                </div>
            {% endif %}
            {% if cv.profil.phone is defined %}
                <div class="contact-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path
                            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.28-2.28a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                    </svg>
                    {{ cv.profil.phone }}
                </div>
            {% endif %}
            {% if cv.profil.location is defined %}
                <div class="contact-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                        <circle cx="12" cy="10" r="3"/>
                    </svg>
                    {{ cv.profil.location.city }}
                </div>
            {% endif %}
            {% for link in cv.profil.links|default([]) %}
                <div class="contact-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                        <polyline points="15 3 21 3 21 9"/>
                        <line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                    <a href="{{ link.url }}" target="_blank">{{ link.network }}</a>
                </div>
            {% endfor %}
        </div>


        {% if groupedSkills|length %}
            <div class="s-section">
                <div class="s-title">Compétences</div>
                {% for type, skills in groupedSkills %}
                    <div style="margin-bottom: 15px;">
                        <div
                            style="font-size: 0.65rem; font-weight: 700; color: var(--text-light); text-transform: uppercase; margin-bottom: 8px;">{{ type }}</div>
                        <div class="tag-list">
                            {% for s in skills %}
                                <span class="tag color-{{ typeToIndex[type] % 12 }}">{{ s.global }}</span>
                            {% endfor %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
        {% if cv.profil.softSkills is defined and cv.profil.softSkills|length %}
            <div class="s-section">
                <div class="s-title">Soft Skills</div>
                <div class="tag-list">
                    {% for soft in cv.profil.softSkills %}
                        <span class="tag">{{ soft }}</span>
                    {% endfor %}
                </div>
            </div>
        {% endif %}
        {% if cv.profil.languages is defined and cv.profil.languages|length %}
            <div class="s-section">
                <div class="s-title">Langues</div>
                {% for lang in cv.profil.languages %}
                    <div class="lang-item">
                        <span>{{ lang.language }}</span>
                        <span class="lang-fluency">{{ lang.fluency }}</span>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
        {% if cv.profil.interests is defined and cv.profil.interests|length %}
            <div class="s-section">
                <div class="s-title">Intérêts</div>
                <div class="tag-list">
                    {% for interest in cv.profil.interests %}
                        {% for kw in interest.keywords|default([]) %}
                            <span class="tag">{{ kw }}</span>
                        {% endfor %}
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </aside>

    <main class="main">
        {% if cv.profil.summary is defined and cv.profil.summary %}
            <div class="section">
                <div class="section-title">À propos</div>
                <p class="summary">{{ cv.profil.summary }}</p>
            </div>
        {% endif %}

        {% if cv.history is defined and cv.history|length %}
            {% set workHistory = cv.history|filter(item => (item.contractType|default('')) != 'student') %}
            <div class="section">
                <div class="section-title">Expérience</div>
                {% for item in workHistory %}
                    <div class="t-item">
                        <div class="t-header">
                            <div>
                                <div class="t-position">{{ item.position }}</div>
                                <div class="t-company">
                                    {{ item.company.name }}
                                    {% if item.company.description %}<span class="t-company-desc">
                                        — {{ item.company.description }}</span>{% endif %}
                                </div>
                                <div class="t-date" data-start="{{ item.startDate }}"
                                     data-end="{{ item.endDate|default('') }}"></div>
                            </div>
                            {% if item.company.logo %}
                                <img src="{{ item.company.logo }}" class="t-logo" alt="{{ item.company.name }}">
                            {% else %}
                                <div class="t-logo"
                                     style="display:flex;align-items:center;justify-content:center;background:var(--bg-sidebar);color:var(--text-light);font-weight:800;font-size:1.2rem;">
                                    DP
                                </div>
                            {% endif %}
                        </div>

                        {% if item.summary is defined and item.summary %}
                            <div class="t-summary">{{ item.summary }}</div>
                        {% endif %}

                        {% if item.highlights is defined and item.highlights %}
                            <ul class="t-highlights">
                                {% for h in item.highlights %}
                                    <li>{{ h }}</li>{% endfor %}
                            </ul>
                        {% endif %}
                        {% if item.skills is defined and item.skills %}
                            <div class="t-keywords">
                                {% for kw in item.skills %}
                                    {% if kw.precision is defined and kw.precision %}
                                        <span
                                            class="t-kw {% if typeToIndex[kw.type] is defined %}color-{{ typeToIndex[kw.type] % 12 }}{% endif %} {% if kw.important is defined and kw.important %}t-kw--important{% endif %}">
                      {{ kw.precision }}
                    </span>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        {% if allReferences|length %}
            <div class="section">
                <div class="section-title">Références</div>
                <div>
                    {% for ref in allReferences %}
                        <div class="t-ref" style="margin-bottom: 30px;">
                            <div class="t-ref-text">« {{ ref.reference|nl2br }} »</div>
                            <div class="t-ref-author">{{ ref.name }}</div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {% if cv.history is defined and cv.history|length %}
            {% set eduHistory = cv.history|filter(item => (item.contractType|default('')) == 'student') %}
            <div class="section">
                <div class="section-title">Formation</div>
                {% for item in eduHistory %}
                    <div class="t-item" style="margin-bottom: 20px;">
                        <div class="t-header">
                            <div>
                                <div class="t-position" style="font-size: 1rem;">{{ item.position }}</div>
                                <div class="t-company">{{ item.company.name }}</div>
                                <div class="t-date" data-start="{{ item.startDate }}"
                                     data-end="{{ item.endDate|default('') }}"></div>
                            </div>
                            {% if item.company.logo %}
                                <img src="{{ item.company.logo }}" class="t-logo" alt="{{ item.company.name }}">
                            {% else %}
                                <div class="t-logo"
                                     style="display:flex;align-items:center;justify-content:center;background:var(--bg-sidebar);color:var(--text-light);font-weight:800;font-size:1.2rem;">
                                    DP
                                </div>
                            {% endif %}
                        </div>

                        {% if item.summary is defined and item.summary %}
                            <div class="t-summary" style="margin-top: 10px;">{{ item.summary }}</div>
                        {% endif %}

                        {% if item.highlights is defined and item.highlights %}
                            <ul class="t-highlights">
                                {% for h in item.highlights %}
                                    <li>{{ h }}</li>{% endfor %}
                            </ul>
                        {% endif %}
                        {% if item.skills is defined and item.skills %}
                            <div class="t-keywords">
                                {% for kw in item.skills %}
                                    {% if kw.precision is defined and kw.precision %}
                                        <span
                                            class="t-kw {% if typeToIndex[kw.type] is defined %}color-{{ typeToIndex[kw.type] % 12 }}{% endif %} {% if kw.important is defined and kw.important %}t-kw--important{% endif %}">
                      {{ kw.precision }}
                    </span>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </main>
</div>

<script>
    const MONTHS = ['Jan.', 'Fév.', 'Mars', 'Avr.', 'Mai', 'Juin', 'Juil.', 'Août', 'Sept.', 'Oct.', 'Nov.', 'Déc.'];

    function fmtDate(iso) {
        if (!iso) return 'Présent';
        const [y, m, d] = iso.split('-');
        return MONTHS[parseInt(m, 10) - 1] + ' ' + y;
    }

    function duration(start, end) {
        const s = new Date(start);
        const e = end ? new Date(end) : new Date();

        const diffTime = Math.abs(e - s);
        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

        if (diffDays < 30) {
            return diffDays + ' jour' + (diffDays > 1 ? 's' : '');
        }

        let m = (e.getFullYear() - s.getFullYear()) * 12 + (e.getMonth() - s.getMonth());
        // Ajustement si le jour de fin est inférieur au jour de début
        if (e.getDate() < s.getDate()) m--;

        if (m < 1) return diffDays + ' jours';

        const y = Math.floor(m / 12);
        const mm = m % 12;
        let res = [];
        if (y) res.push(y + ' an' + (y > 1 ? 's' : ''));
        if (mm) res.push(mm + ' mois');
        return res.join(' ');
    }

    document.querySelectorAll('.t-date[data-start]').forEach(el => {
        const s = el.dataset.start;
        const e = el.dataset.end;
        const durTxt = duration(s, e);

        el.innerHTML = fmtDate(s) + ' — ' + fmtDate(e) +
            (durTxt ? ' <span class="t-duration">' + durTxt + '</span>' : '');
    });
</script>
</body>
</html>
